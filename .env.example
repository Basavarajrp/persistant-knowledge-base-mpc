# ============================================================================
# Knowledge Graph MCP Server - Complete Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to git (it contains secrets)
# ============================================================================

# ============================================================================
# NEO4J DATABASE CONFIGURATION
# ============================================================================
# Neo4j connection details
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=Neo4j@123

# NEO4J_PASSWORD explained:
# - Used by docker-compose to create admin user
# - Used by MCP server to connect to database
# - Change this to a strong password before running docker compose up
# Example: NEO4J_PASSWORD=SecureP@ssw0rd123!

# ============================================================================
# EMBEDDING MODEL CONFIGURATION
# ============================================================================
# Model used for vector embeddings (local, auto-downloads on first use)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Other available models (install sentence-transformers separately):
# - all-mpnet-base-v2 (higher quality, slower, larger)
# - multi-qa-MiniLM-L6-cos-v1 (optimized for Q&A)
# - distiluse-base-multilingual-cased-v2 (multilingual support)

# ============================================================================
# VECTOR SEARCH & DEDUPLICATION SETTINGS
# ============================================================================
# Cosine similarity threshold for duplicate detection (0.0 to 1.0)
# Higher value = stricter (fewer false duplicates)
# Lower value = more permissive (fewer unique entries)
# Recommended: 0.90 - 0.98
DUPLICATE_THRESHOLD=0.95

# Maximum number of related facts retrieved during graph traversal
# Higher = more context but slower queries and more tokens for Claude
# Recommended: 2 - 5
MAX_RELATED_FACTS=3

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level for the MCP server
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================================
# VECTOR SEARCH CONFIGURATION
# ============================================================================
# Number of top-k neighbors to retrieve from vector index before graph traversal
# Higher = more candidates but slower search
# Recommended: 3 - 10
VECTOR_SEARCH_TOP_K=5

# ============================================================================
# DATABASE CONNECTION POOL SETTINGS
# ============================================================================
# Neo4j driver connection pool size
# Higher = more concurrent connections but more memory
# Recommended: 5 - 20
NEO4J_POOL_SIZE=10

# ============================================================================
# TIMEOUT SETTINGS (in seconds)
# ============================================================================
# Maximum time for Neo4j query execution
NEO4J_QUERY_TIMEOUT=30

# Maximum time for embedding computation (affects first-run model download)
EMBEDDING_COMPUTE_TIMEOUT=60

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# MCP transport type (currently only stdio supported for Claude Desktop)
MCP_TRANSPORT=stdio

# ============================================================================
# OPTIONAL: ADVANCED SETTINGS
# ============================================================================

# Neo4j memory settings (can also be set in docker-compose.yml)
# NEO4J_MEMORY_HEAP_INITIAL_SIZE=512m
# NEO4J_MEMORY_HEAP_MAX_SIZE=1G
# NEO4J_MEMORY_PAGECACHE_SIZE=512m

# Fact storage limits (to prevent unbounded growth)
# MAX_FACTS_PER_PROFILE=10000
# MAX_CATEGORIES_PER_PROFILE=100

# Embedding cache size (number of embeddings to cache in memory)
# EMBEDDING_CACHE_SIZE=1000

# ============================================================================
# NOTES
# ============================================================================
# - .env is git-ignored (never commit secrets)
# - All values can be overridden in docker-compose.yml if needed
# - Environment variables are read by both docker-compose and Python code
# - First embedding model download: ~2 minutes, ~80MB (cached after)
# - Docker Compose uses env_file: [.env] to load these values automatically